<Window x:Class="ListBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="List Browser" Height="600" Width="1000" MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: URL List Panel -->
        <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2C3E50" Padding="12,10">
                    <Grid>
                        <TextBlock Text="URL リスト" Foreground="White" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Content="＋ 追加" Click="AddUrl_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Padding="10,5" Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"/>
                    </Grid>
                </Border>

                <ListBox x:Name="UrlListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         SelectionChanged="UrlListBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D6EAF8"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EBF5FB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding}" TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" FontSize="12" Foreground="#2C3E50"
                                           ToolTip="{Binding}"/>
                                <Button Grid.Column="1" Content="✕"
                                        Click="DeleteUrl_Click" Tag="{Binding}"
                                        Margin="6,0,0,0" Padding="6,3"
                                        Background="#E74C3C" Foreground="White"
                                        BorderThickness="0" Cursor="Hand" FontSize="10"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#CCCCCC" Cursor="SizeWE"/>

        <!-- Right: WebView2 Panel -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#34495E" Padding="10,8">
                <TextBlock x:Name="CurrentUrlText" Text="URLを選択してください"
                           Foreground="#BDC3C7" FontSize="11" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"/>
            </Border>

            <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>
        </Grid>
    </Grid>
</Window>
