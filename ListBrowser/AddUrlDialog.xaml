<Window x:Class="ListBrowser.AddUrlDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="URLを追加" Height="220" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="URLを入力してください:" FontSize="13" Margin="0,0,0,8" Foreground="#2C3E50"/>

        <TextBox x:Name="UrlTextBox" Grid.Row="1"
                 AcceptsReturn="False" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontSize="13" Padding="8"
                 BorderBrush="#BDC3C7" BorderThickness="1"
                 VerticalContentAlignment="Top"
                 MinHeight="60"
                 KeyDown="UrlTextBox_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="キャンセル" Click="Cancel_Click"
                    Width="90" Padding="0,7"
                    Background="#95A5A6" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Margin="0,0,8,0"/>
            <Button Content="追加" Click="Add_Click"
                    Width="90" Padding="0,7"
                    Background="#2980B9" Foreground="White" BorderThickness="0"
                    Cursor="Hand" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
